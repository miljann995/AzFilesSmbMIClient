<Project>
  <!-- Automatically copy the native DLL to output directory when package is consumed -->
  <ItemGroup>
    <Content Include="$(MSBuildThisFileDirectory)../runtimes/win-x64/native/AzFilesSmbMI.dll" Condition="Exists('$(MSBuildThisFileDirectory)../runtimes/win-x64/native/AzFilesSmbMI.dll') AND ('$(Platform)' == 'x64' OR '$(PlatformTarget)' == 'x64' OR ('$(Platform)' == '' AND '$(PlatformTarget)' == ''))">
      <CopyToOutputDirectory>PreserveNewest</CopyToOutputDirectory>
      <Visible>false</Visible>
    </Content>
    <Content Include="$(MSBuildThisFileDirectory)../runtimes/win-arm64/native/AzFilesSmbMI.dll" Condition="Exists('$(MSBuildThisFileDirectory)../runtimes/win-arm64/native/AzFilesSmbMI.dll') AND ('$(Platform)' == 'ARM64' OR '$(PlatformTarget)' == 'ARM64')">
      <CopyToOutputDirectory>PreserveNewest</CopyToOutputDirectory>
      <Visible>false</Visible>
    </Content>
  </ItemGroup>
</Project>